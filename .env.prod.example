# Database credentials (used by both MariaDB container init and PHP app)
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=mybs
MYSQL_USER=mybs_user
MYSQL_PASSWORD=change_this_password
DB_PREFIX=mb_

# phpMyAdmin
PMA_PASSWORD=change_this_root_password

# Application
APP_NAME=Finance Manager
COOKIE_VALIDATION_KEY=generate_a_random_32_char_string_here

# Mail — SMTP DSN format: smtp://user:password@host:port
# Use null://null to disable mail
MAIL_DSN=smtp://user:password@smtp.host:587
